{%- style -%}
  #cx-heading-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 20px 0; 
  }

  /* 🟢 WRAPPER: Removed fixed max-width to allow global container control */
  .cx-heading-wrapper {
    width: 100%;
    margin: 0 auto;
    padding: 0 20px; 
  }

  .cx-heading-container {
    display: flex;
    flex-direction: column;
    text-align: {{ section.settings.text_align }};
    /* Align items logic for Flexbox based on text alignment */
    align-items: {% if section.settings.text_align == 'left' %}flex-start{% elsif section.settings.text_align == 'right' %}flex-end{% else %}center{% endif %};
  }

  .cx-main-title { margin: 0; line-height: 1.2; word-break: break-word; color: {{ section.settings.title_color }}; width: 100%; }
  .cx-sub-title { margin: 0; line-height: 1.4; word-break: break-word; color: {{ section.settings.subtitle_color }}; width: 100%; }

  /* 🟢 Desktop Styles */
  @media screen and (min-width: 751px) {
    .cx-main-title { font-size: {{ section.settings.title_size }}px; }
    .cx-sub-title { font-size: {{ section.settings.subtitle_size }}px; }
    
    #title-wrapper-{{ section.id }} {
      margin-top: {{ section.settings.title_mt }}px;
      margin-bottom: {{ section.settings.title_mb }}px;
      padding-top: {{ section.settings.title_pt }}px;
      padding-bottom: {{ section.settings.title_pb }}px;
    }
    #subtitle-wrapper-{{ section.id }} {
      margin-top: {{ section.settings.subtitle_mt }}px;
      margin-bottom: {{ section.settings.subtitle_mb }}px;
      padding-top: {{ section.settings.subtitle_pt }}px;
      padding-bottom: {{ section.settings.subtitle_pb }}px;
    }
    #html-wrapper-{{ section.id }} {
      margin-top: {{ section.settings.html_mt }}px;
      margin-bottom: {{ section.settings.html_mb }}px;
    }
  }

  /* 🟢 Mobile Styles */
  @media screen and (max-width: 750px) {
    .cx-main-title { font-size: {{ section.settings.title_size_mobile }}px; }
    .cx-sub-title { font-size: {{ section.settings.subtitle_size_mobile }}px; }

    #title-wrapper-{{ section.id }} {
      margin-top: {{ section.settings.title_mt_m }}px !important;
      margin-bottom: {{ section.settings.title_mb_m }}px !important;
      padding-top: {{ section.settings.title_pt_m }}px !important;
      padding-bottom: {{ section.settings.title_pb_m }}px !important;
    }
    #subtitle-wrapper-{{ section.id }} {
      margin-top: {{ section.settings.subtitle_mt_m }}px !important;
      margin-bottom: {{ section.settings.subtitle_mb_m }}px !important;
      padding-top: {{ section.settings.subtitle_pt_m }}px !important;
      padding-bottom: {{ section.settings.subtitle_pb_m }}px !important;
    }
    #html-wrapper-{{ section.id }} {
      margin-top: {{ section.settings.html_mt_m }}px !important;
      margin-bottom: {{ section.settings.html_mb_m }}px !important;
    }
  }
{%- endstyle -%}

<div id="cx-heading-{{ section.id }}" class="cx-custom-heading-section">
  <div class="cx-heading-wrapper">
    <div class="cx-heading-container">

      {%- assign html_content = section.settings.custom_html | strip -%}
      {% if html_content != blank %}
        <div id="html-wrapper-{{ section.id }}" class="cx-custom-html-box">
          {{ section.settings.custom_html }}
        </div>
      {% endif %}

      {%- assign title_content = section.settings.title | strip -%}
      {% if title_content != blank %}
        <div id="title-wrapper-{{ section.id }}" class="cx-main-title-wrapper">
          <h1 class="cx-main-title">{{ section.settings.title }}</h1>
        </div>
      {% endif %}

      {%- assign subtitle_content = section.settings.subtitle | strip -%}
      {% if subtitle_content != blank %}
        <div id="subtitle-wrapper-{{ section.id }}" class="cx-sub-title-wrapper">
          <h2 class="cx-sub-title">{{ section.settings.subtitle }}</h2>
        </div>
      {% endif %}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "CX-Custom-Heading",
  "settings": [
    { "type": "header", "content": "Global Settings" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "select", "id": "text_align", "label": "Alignment", "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ], "default": "center" },

    { "type": "header", "content": "1. Custom HTML (Desktop)" },
    { "type": "html", "id": "custom_html", "label": "HTML Code" },
    { "type": "range", "id": "html_mt", "min": 0, "max": 100, "step": 1, "unit": "px", "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "html_mb", "min": 0, "max": 100, "step": 1, "unit": "px", "label": "Margin Bottom", "default": 0 },
    { "type": "header", "content": "Custom HTML (Mobile)" },
    { "type": "range", "id": "html_mt_m", "min": 0, "max": 100, "step": 1, "unit": "px", "label": "Margin Top Mobile", "default": 0 },
    { "type": "range", "id": "html_mb_m", "min": 0, "max": 100, "step": 1, "unit": "px", "label": "Margin Bottom Mobile", "default": 0 },

    { "type": "header", "content": "2. Main Heading (Desktop)" },
    { "type": "text", "id": "title", "label": "Text", "default": "Main Title" },
    { "type": "color", "id": "title_color", "label": "Color", "default": "#000000" },
    { "type": "range", "id": "title_size", "min": 10, "max": 100, "label": "Font Size", "default": 40 },
    { "type": "range", "id": "title_mt", "min": 0, "max": 100, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "title_mb", "min": 0, "max": 100, "label": "Margin Bottom", "default": 10 },
    { "type": "range", "id": "title_pt", "min": 0, "max": 100, "label": "Padding Top", "default": 0 },
    { "type": "range", "id": "title_pb", "min": 0, "max": 100, "label": "Padding Bottom", "default": 0 },
    { "type": "header", "content": "Main Heading (Mobile)" },
    { "type": "range", "id": "title_size_mobile", "min": 10, "max": 80, "label": "Font Size Mobile", "default": 24 },
    { "type": "range", "id": "title_mt_m", "min": 0, "max": 100, "label": "Margin Top Mobile", "default": 0 },
    { "type": "range", "id": "title_mb_m", "min": 0, "max": 100, "label": "Margin Bottom Mobile", "default": 5 },
    { "type": "range", "id": "title_pt_m", "min": 0, "max": 100, "label": "Padding Top Mobile", "default": 0 },
    { "type": "range", "id": "title_pb_m", "min": 0, "max": 100, "label": "Padding Bottom Mobile", "default": 0 },

    { "type": "header", "content": "3. Sub-Heading (Desktop)" },
    { "type": "text", "id": "subtitle", "label": "Text", "default": "Sub-heading text" },
    { "type": "color", "id": "subtitle_color", "label": "Color", "default": "#444444" },
    { "type": "range", "id": "subtitle_size", "min": 10, "max": 80, "label": "Font Size", "default": 20 },
    { "type": "range", "id": "subtitle_mt", "min": 0, "max": 100, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "subtitle_mb", "min": 0, "max": 100, "label": "Margin Bottom", "default": 0 },
    { "type": "range", "id": "subtitle_pt", "min": 0, "max": 100, "label": "Padding Top", "default": 0 },
    { "type": "range", "id": "subtitle_pb", "min": 0, "max": 100, "label": "Padding Bottom", "default": 0 },
    { "type": "header", "content": "Sub-Heading (Mobile)" },
    { "type": "range", "id": "subtitle_size_mobile", "min": 10, "max": 60, "label": "Font Size Mobile", "default": 16 },
    { "type": "range", "id": "subtitle_mt_m", "min": 0, "max": 100, "label": "Margin Top Mobile", "default": 0 },
    { "type": "range", "id": "subtitle_mb_m", "min": 0, "max": 100, "label": "Margin Bottom Mobile", "default": 0 },
    { "type": "range", "id": "subtitle_pt_m", "min": 0, "max": 100, "label": "Padding Top Mobile", "default": 0 },
    { "type": "range", "id": "subtitle_pb_m", "min": 0, "max": 100, "label": "Padding Bottom Mobile", "default": 0 }
  ],
  "presets": [ { "name": "CX-Custom-Heading" } ]
}
{% endschema %}