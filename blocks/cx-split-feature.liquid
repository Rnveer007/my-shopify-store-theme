{%- style -%}
  #cx-split-{{ block.id }} {
    background-color: {{ block.settings.bg_color }};
    padding-top: {{ block.settings.section_padding_t }}px;
    padding-bottom: {{ block.settings.section_padding_b }}px;
    position: relative;
    z-index: 1;
    overflow: hidden;
    width: 100%;
  }

  /* 🟢 CONTAINER: Takes full space of the parent (Container Block) */
  .cx-split-wrapper-{{ block.id }} {
    width: 100%;
    margin: 0 auto;
  }

  .cx-split-container-{{ block.id }} {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 40px;
    flex-direction: {% if block.settings.img_position == 'right' %}row-reverse{% else %}row{% endif %};
  }

  .cx-split-image-{{ block.id }}, 
  .cx-split-content-{{ block.id }} {
    flex: 1;
    min-width: min(100%, 350px); 
  }

  /* Image Display Logic */
  .cx-split-image-{{ block.id }} img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.img_rounded }}px;
    object-fit: cover;
  }

  .desktop-img-{{ block.id }} { display: block !important; }
  .mobile-img-{{ block.id }} { display: none !important; }

  @media screen and (max-width: 750px) {
    .desktop-img-{{ block.id }} { display: none !important; }
    .mobile-img-{{ block.id }} { display: block !important; }
    
    .cx-split-container-{{ block.id }} {
      flex-direction: column{% if block.settings.mob_img_first == false %}-reverse{% endif %};
      gap: 20px;
    }
  }

  /* Logo & Content Styles */
  .cx-feature-logo-{{ block.id }} {
    max-width: {{ block.settings.logo_width }}px;
    margin-bottom: 20px;
    display: block;
    {% if block.settings.text_align == 'center' %}margin-left: auto; margin-right: auto;{% endif %}
  }

  .cx-split-content-{{ block.id }} { text-align: {{ block.settings.text_align }}; }
  
  .cx-split-title-{{ block.id }} { 
    margin: 0 0 15px 0; 
    color: {{ block.settings.title_color }}; 
    font-weight: bold; 
    line-height: 1.1; 
  }

  .cx-split-subtitle-{{ block.id }} { 
    margin: 0 0 25px 0; 
    color: {{ block.settings.subtitle_color }}; 
    line-height: 1.5; 
  }

  @media screen and (min-width: 751px) {
    .cx-split-title-{{ block.id }} { font-size: {{ block.settings.title_size }}px; }
    .cx-split-subtitle-{{ block.id }} { font-size: {{ block.settings.subtitle_size }}px; }
  }
  @media screen and (max-width: 750px) {
    .cx-split-title-{{ block.id }} { font-size: {{ block.settings.title_size_mob }}px; }
    .cx-split-subtitle-{{ block.id }} { font-size: {{ block.settings.subtitle_size_mob }}px; }
  }

  .cx-split-btn-{{ block.id }} {
    display: inline-block;
    padding: 14px 40px;
    border-radius: 4px;
    font-weight: bold;
    text-decoration: none;
    background-color: {{ block.settings.btn_bg }};
    color: {{ block.settings.btn_text_color }} !important;
    transition: opacity 0.2s;
  }
  .cx-split-btn-{{ block.id }}:hover { opacity: 0.8; }
{%- endstyle -%}

<div id="cx-split-{{ block.id }}" class="cx-split-feature-block">
  <div class="cx-split-wrapper-{{ block.id }}">
    <div class="cx-split-container-{{ block.id }}">
      
      <div class="cx-split-image-{{ block.id }}">
        {% if block.settings.image_desktop != blank %}
          <div class="desktop-img-{{ block.id }}">
            <img src="{{ block.settings.image_desktop | image_url: width: 1400 }}" loading="lazy" alt="Desktop">
          </div>
        {% endif %}

        <div class="mobile-img-{{ block.id }}">
          {% if block.settings.image_mobile != blank %}
            <img src="{{ block.settings.image_mobile | image_url: width: 800 }}" loading="lazy" alt="Mobile">
          {% elsif block.settings.image_desktop != blank %}
            <img src="{{ block.settings.image_desktop | image_url: width: 800 }}" loading="lazy" alt="Fallback">
          {% endif %}
        </div>

        {% if block.settings.image_desktop == blank and block.settings.image_mobile == blank %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>

      <div class="cx-split-content-{{ block.id }}">
        {% if block.settings.feature_logo != blank %}
          <img src="{{ block.settings.feature_logo | image_url: width: 400 }}" class="cx-feature-logo-{{ block.id }}" loading="lazy">
        {% endif %}

        {% if block.settings.title != blank %}
          <h2 class="cx-split-title-{{ block.id }}">{{ block.settings.title }}</h2>
        {% endif %}

        {% if block.settings.subtitle != blank %}
          <div class="cx-split-subtitle-{{ block.id }}">{{ block.settings.subtitle }}</div>
        {% endif %}

        {% if block.settings.btn_label != blank %}
          <a href="{{ block.settings.btn_link }}" class="cx-split-btn-{{ block.id }}">
            {{ block.settings.btn_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "CX Split Feature",
  "settings": [
    { "type": "header", "content": "Layout Settings" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "transparent" },
    { "type": "select", "id": "img_position", "label": "Desktop Image Position", "options": [
        { "value": "left", "label": "Left" }, { "value": "right", "label": "Right" }
      ], "default": "left" },
    { "type": "checkbox", "id": "mob_img_first", "label": "Mobile: Image First?", "default": true },
    { "type": "range", "id": "section_padding_t", "min": 0, "max": 150, "step": 5, "unit": "px", "label": "Padding Top", "default": 40 },
    { "type": "range", "id": "section_padding_b", "min": 0, "max": 150, "step": 5, "unit": "px", "label": "Padding Bottom", "default": 40 },
    { "type": "header", "content": "Image Settings" },
    { "type": "image_picker", "id": "image_desktop", "label": "Desktop Image" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile Image" },
    { "type": "range", "id": "img_rounded", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Corner Roundness", "default": 0 },
    { "type": "header", "content": "Logo/Icon Settings" },
    { "type": "image_picker", "id": "feature_logo", "label": "Feature Logo/Icon" },
    { "type": "range", "id": "logo_width", "min": 30, "max": 400, "step": 10, "label": "Logo Width", "default": 120 },
    { "type": "header", "content": "Content Settings" },
    { "type": "select", "id": "text_align", "label": "Text Alignment", "options": [
        { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" }
      ], "default": "left" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Our Story" },
    { "type": "color", "id": "title_color", "label": "Heading Color", "default": "#1a1a1a" },
    { "type": "range", "id": "title_size", "min": 20, "max": 100, "label": "Desktop Font Size", "default": 42 },
    { "type": "range", "id": "title_size_mob", "min": 15, "max": 80, "label": "Mobile Font Size", "default": 28 },
    { "type": "richtext", "id": "subtitle", "label": "Description", "default": "<p>Share details about your brand story here.</p>" },
    { "type": "color", "id": "subtitle_color", "label": "Description Color", "default": "#4a4a4a" },
    { "type": "range", "id": "subtitle_size", "min": 12, "max": 40, "label": "Desktop Font Size", "default": 18 },
    { "type": "range", "id": "subtitle_size_mob", "min": 10, "max": 30, "label": "Mobile Font Size", "default": 16 },
    { "type": "header", "content": "Button Settings" },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "Shop Now" },
    { "type": "url", "id": "btn_link", "label": "Button Link" },
    { "type": "color", "id": "btn_bg", "label": "Button Background", "default": "#000000" },
    { "type": "color", "id": "btn_text_color", "label": "Button Text", "default": "#ffffff" }
  ],
  "presets": [ { "name": "CX Split Feature" } ]
}
{% endschema %}