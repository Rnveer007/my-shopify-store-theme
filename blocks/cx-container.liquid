{%- liquid
  assign custom_id = block.settings.custom_id | default: block.id
  assign max_width = block.settings.max_width
  assign bg_color = block.settings.background_color
  
  # Desktop Spacing
  assign pt_d = block.settings.top_padding_desktop
  assign pb_d = block.settings.bottom_padding_desktop
  # Mobile Spacing
  assign pt_m = block.settings.top_padding
  assign pb_m = block.settings.bottom_padding
-%}

{%- style -%}
  #cx-container-{{ block.id }} {
    background-color: {{ bg_color }};
    padding-top: {{ pt_m }}px;
    padding-bottom: {{ pb_m }}px;
    width: 100%;
    position: relative;
    display: flex;
    justify-content: center;
    overflow: hidden;
  }

  .cx-inner-{{ block.id }} {
    width: 100%;
    margin: 0 auto;
    /* Max Width Control */
    {% if max_width == 1920 %}
      max-width: 100%;
      padding: 0;
    {% else %}
      max-width: {{ max_width }}px;
      padding: 0 20px; /* Safety gutter for boxed layout */
    {% endif %}
    position: relative;
    z-index: 2;
  }

  @media screen and (min-width: 750px) {
    #cx-container-{{ block.id }} {
      padding-top: {{ pt_d }}px;
      padding-bottom: {{ pb_d }}px;
    }
  }
{%- endstyle -%}

<div id="cx-container-{{ block.id }}" class="cx-container-block" data-block-id="{{ custom_id }}">
  <div class="cx-inner-{{ block.id }}">
    {%- comment -%} 
      Asli Power: Yahan saare "Paste Inside" blocks render honge 
    {%- endcomment -%}
    {% content_for 'blocks' %}
  </div>
</div>

{% schema %}
{
  "name": "CX Container",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "label": "Container Max Width",
      "default": 1440,
      "info": "Set to 1920 for Full Width (No Gutter)"
    },
    { "type": "color", "id": "background_color", "label": "Background Color", "default": "#ffffff" },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    { "type": "range", "id": "top_padding_desktop", "min": 0, "max": 200, "step": 5, "unit": "px", "label": "Top Padding (Desktop)", "default": 60 },
    { "type": "range", "id": "bottom_padding_desktop", "min": 0, "max": 200, "step": 5, "unit": "px", "label": "Bottom Padding (Desktop)", "default": 60 },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    { "type": "range", "id": "top_padding", "min": 0, "max": 150, "step": 5, "unit": "px", "label": "Top Padding (Mobile)", "default": 30 },
    { "type": "range", "id": "bottom_padding", "min": 0, "max": 150, "step": 5, "unit": "px", "label": "Bottom Padding (Mobile)", "default": 30 },
    {
      "type": "header",
      "content": "Advanced"
    },
    { "type": "text", "id": "custom_id", "label": "Custom Anchor ID", "info": "For jump links" }
  ],
  "presets": [
    { "name": "CX Container" }
  ]
}
{% endschema %}