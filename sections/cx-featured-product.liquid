<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<div class="cx-slider-section" id="section-{{ section.id }}">
  <div class="container">
    {% if section.settings.title != blank %}
      <h2 class="section-main-title">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="swiper cxSwiper-{{ section.id }} {% if section.settings.mobile_layout == 'column' %}mobile-grid-mode{% endif %}">
      <div class="swiper-wrapper">
        {%- assign collection = section.settings.collection -%}
        
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <div class="swiper-slide">
            <div class="cx-product-card">
              <a href="{{ product.url }}" class="card-link">
                <div class="card-image-wrapper">
                  <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy">
                </div>

                <div class="card-info">
                  {% if section.settings.show_name %}
                    <h3 class="card-title">{{ product.title }}</h3>
                  {% endif %}
                  
                  {% if section.settings.show_rating %}
                    <div class="card-rating">⭐⭐⭐⭐⭐</div> {% endif %}

                  {% if section.settings.show_price %}
                    <div class="card-price">
                      <span class="price-current">{{ product.price | money }}</span>
                    </div>
                  {% endif %}

                  {% if section.settings.show_swatches %}
                    <div class="card-swatches">
                      <span class="swatch" style="background: black;"></span>
                      <span class="swatch" style="background: blue;"></span>
                    </div>
                  {% endif %}
                </div>
              </a>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {% if section.settings.mobile_layout != 'column' %}
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  #section-{{ section.id }} { padding: 50px 20px; background-color: {{ section.settings.bg_color }}; }
  .container { max-width: 1400px; margin: 0 auto; position: relative; }
  .section-main-title { text-align: center; margin-bottom: 40px; }

  /* Card Styling */
  .cx-product-card { background: #fff; border-radius: 8px; overflow: hidden; }
  .card-image-wrapper { aspect-ratio: 1/1; background: #f0f0f0; }
  .card-image-wrapper img { width: 100%; height: 100%; object-fit: cover; }
  .card-info { padding: 15px; text-align: center; }
  .card-title { font-size: 14px; margin-bottom: 8px; }
  .price-current { font-weight: bold; }
  .card-swatches { display: flex; justify-content: center; gap: 5px; margin-top: 10px; }
  .swatch { width: 15px; height: 15px; border-radius: 50%; border: 1px solid #ddd; }

  /* Navigation Customization */
  .swiper-button-next, .swiper-button-prev { color: #000; transform: scale(0.6); background: rgba(255,255,255,0.8); width: 50px; height: 50px; border-radius: 50%; }

  /* Mobile Logic */
  @media screen and (max-width: 768px) {
    .mobile-grid-mode .swiper-wrapper {
      display: grid !important;
      grid-template-columns: 1fr 1fr;
      gap: 15px;
      transform: none !important;
    }
    .mobile-grid-mode .swiper-slide { width: 100% !important; margin: 0 !important; }
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  new Swiper(".cxSwiper-{{ section.id }}", {
    slidesPerView: 2,
    spaceBetween: 20,
    navigation: { nextEl: ".swiper-button-next", prevEl: ".swiper-button-prev" },
    breakpoints: {
      1024: { slidesPerView: {{ section.settings.cols_desktop }} }
    }
  });
</script>

{% schema %}
{
  "name": "CX Premium Slider",
  "settings": [
    { "type": "text", "id": "title", "label": "Slider Heading", "default": "Featured Slider" },
    { "type": "collection", "id": "collection", "label": "Select Collection" },
    { "type": "range", "id": "cols_desktop", "min": 3, "max": 6, "step": 1, "label": "Products per Row (Desktop)", "default": 4 },
    { "type": "select", "id": "mobile_layout", "label": "Mobile Layout", "options": [
        { "value": "slider", "label": "Slider (Horizontal)" },
        { "value": "column", "label": "Grid (2 Columns)" }
      ], "default": "slider" },
    { "type": "header", "content": "Show/Hide Controls" },
    { "type": "checkbox", "id": "show_name", "label": "Show Name", "default": true },
    { "type": "checkbox", "id": "show_price", "label": "Show Price", "default": true },
    { "type": "checkbox", "id": "show_rating", "label": "Show Rating", "default": false },
    { "type": "checkbox", "id": "show_swatches", "label": "Show Swatches", "default": false },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" }
  ],
  "presets": [ { "name": "CX Premium Slider" } ]
}
{% endschema %}