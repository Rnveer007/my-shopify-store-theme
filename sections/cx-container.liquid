{%- style -%}
  #cx-wrap-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.pt_d }}px;
    padding-bottom: {{ section.settings.pb_d }}px;
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
    {% endif %}
  }

  .cx-wrap-inner {
    margin: 0 auto;
    width: 100%;
    /* 🟢 Gutter / No-Gutter Logic */
    {% if section.settings.no_gutter %}
      max-width: 100%; /* Becomes Full Width */
      padding: 0;
    {% else %}
      max-width: 1440px;
      padding: 0 20px;
    {% endif %}
  }

  @media screen and (max-width: 750px) {
    #cx-wrap-{{ section.id }} {
      padding-top: {{ section.settings.pt_m }}px;
      padding-bottom: {{ section.settings.pb_m }}px;
    }
  }
{%- endstyle -%}

<div id="cx-wrap-{{ section.id }}" class="cx-master-wrapper">
  <div class="cx-wrap-inner">
    
    {%- for block in section.blocks -%}
      <div class="cx-inner-block-item" {{ block.shopify_attributes }}>
        
        {%- case block.type -%}
          {%- when 'section_content' -%}
            {%- comment -%} 
               Bhai, ye wo block hai jahan tum doosre sections ka 
               HTML code "paste" karoge. 
            {%- endcomment -%}
            {{ block.settings.pasted_html }}

          {%- when '@app' -%}
            {% render block %}
        {%- endcase -%}
        
      </div>
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "CX-Container",
  "settings": [
    { "type": "checkbox", "id": "no_gutter", "label": "No Gutter (Full Width)", "default": false },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "image_picker", "id": "bg_image", "label": "Background Image (Desktop)" },
    { "type": "header", "content": "Desktop Spacing" },
    { "type": "range", "id": "pt_d", "min": 0, "max": 150, "step": 2, "label": "Top Padding", "default": 40 },
    { "type": "range", "id": "pb_d", "min": 0, "max": 150, "step": 2, "label": "Bottom Padding", "default": 40 },
    { "type": "header", "content": "Mobile Spacing" },
    { "type": "range", "id": "pt_m", "min": 0, "max": 100, "step": 2, "label": "Top Padding Mobile", "default": 20 },
    { "type": "range", "id": "pb_m", "min": 0, "max": 100, "step": 2, "label": "Bottom Padding Mobile", "default": 20 }
  ],
  "blocks": [
    {
      "type": "section_content",
      "name": "Inner Section HTML",
      "settings": [
        {
          "type": "html",
          "id": "pasted_html",
          "label": "Pasted Section HTML",
          "info": "Copy the rendered HTML of any section and paste here."
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "presets": [ { "name": "CX-Container" } ]
}
{% endschema %}