{%- style -%}
  #cx-shell-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.pt_d }}px 0 {{ section.settings.pb_d }}px 0;
    position: relative;
    overflow: hidden;
  }

  .cx-shell-inner {
    margin: 0 auto;
    width: 100%;
    transition: max-width 0.3s ease;
    {% if section.settings.no_gutter %}
      max-width: 1920px;
      padding: 0;
    {% else %}
      max-width: 1440px;
      padding: 0 20px;
    {% endif %}
  }

  @media screen and (max-width: 750px) {
    #cx-shell-{{ section.id }} {
      padding: {{ section.settings.pt_m }}px 0 {{ section.settings.pb_m }}px 0;
    }
  }
{%- endstyle -%}

<section id="cx-shell-{{ section.id }}">
  <div class="cx-shell-inner">
    {% for block in section.blocks %}
      <div class="cx-container-block" {{ block.shopify_attributes }}>
        
        {% case block.type %}
          
          {% when 'heading_block' %}
            {%- comment -%} Is block mein Heading ka logic dalo {%- endcomment -%}
            <div style="text-align: {{ block.settings.align }}; margin-bottom: 20px;">
               <h2 style="font-size: {{ block.settings.size }}px; color: {{ block.settings.color }};">{{ block.settings.text }}</h2>
            </div>

          {% when 'split_feature_block' %}
            {%- comment -%} Is block mein Split Feature ka logic dalo {%- endcomment -%}
            {% render 'cx-split-logic', block: block %}

        {% endcase %}
        
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "CX-Ultimate-Container",
  "settings": [
    { "type": "checkbox", "id": "no_gutter", "label": "No Gutter (1920px)", "default": false },
    { "type": "color", "id": "bg_color", "label": "BG Color", "default": "#ffffff" },
    { "type": "header", "content": "Desktop Spacing" },
    { "type": "range", "id": "pt_d", "min": 0, "max": 150, "label": "Top", "default": 60 },
    { "type": "range", "id": "pb_d", "min": 0, "max": 150, "label": "Bottom", "default": 60 },
    { "type": "header", "content": "Mobile Spacing" },
    { "type": "range", "id": "pt_m", "min": 0, "max": 100, "label": "Top Mobile", "default": 30 },
    { "type": "range", "id": "pb_m", "min": 0, "max": 100, "label": "Bottom Mobile", "default": 30 }
  ],
  "blocks": [
    {
      "type": "heading_block",
      "name": "Heading Block",
      "settings": [
        { "type": "text", "id": "text", "label": "Heading", "default": "Block Heading" },
        { "type": "color", "id": "color", "label": "Color", "default": "#000000" },
        { "type": "range", "id": "size", "min": 20, "max": 80, "label": "Size", "default": 32 },
        { "type": "select", "id": "align", "label": "Align", "options": [
            {"value": "left", "label": "Left"}, {"value": "center", "label": "Center"}
          ], "default": "center"}
      ]
    }
  ],
  "presets": [ { "name": "CX-Ultimate-Container" } ]
}
{% endschema %}