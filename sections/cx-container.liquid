{%- style -%}
  #cx-container-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.pt_d }}px;
    padding-bottom: {{ section.settings.pb_d }}px;
    width: 100%;
    position: relative;
  }

  /* 🟢 THE WRAPPER LOGIC (1440px vs Full) */
  .cx-container-inner {
    margin: 0 auto;
    width: 100%;
    transition: max-width 0.3s ease-in-out;
    {% if section.settings.no_gutter %}
      max-width: 100%;
      padding: 0;
    {% else %}
      max-width: 1440px;
      padding: 0 20px;
    {% endif %}
  }

  @media screen and (max-width: 750px) {
    #cx-container-{{ section.id }} {
      padding-top: {{ section.settings.pt_m }}px;
      padding-bottom: {{ section.settings.pb_m }}px;
    }
  }

  /* Block spacing inside container */
  .cx-nested-block { margin-bottom: {{ section.settings.block_gap }}px; width: 100%; }
  .cx-nested-block:last-child { margin-bottom: 0; }
{%- endstyle -%}

<div id="cx-container-{{ section.id }}" class="cx-section-main-wrapper">
  <div class="cx-container-inner">
    
    {%- for block in section.blocks -%}
      <div class="cx-nested-block" {{ block.shopify_attributes }}>
        
        {%- case block.type -%}
          
          {%- when 'heading' -%}
            {%- comment -%} Copy of your CX Heading logic {%- endcomment -%}
            <div style="text-align: {{ block.settings.align }};">
              <h2 style="color: {{ block.settings.color }}; font-size: {{ block.settings.size }}px; margin: 0;">
                {{ block.settings.text }}
              </h2>
            </div>

          {%- when 'liquid' -%}
            {%- comment -%} For pasting custom section code {%- endcomment -%}
            {{ block.settings.custom_liquid }}

          {%- when '@app' -%}
            {% render block %}

        {%- endcase -%}
        
      </div>
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "CX Container",
  "settings": [
    { "type": "checkbox", "id": "no_gutter", "label": "No Gutter (1920px / Full)", "default": false },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "header", "content": "Container Spacing" },
    { "type": "range", "id": "block_gap", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Gap Between Blocks", "default": 20 },
    { "type": "header", "content": "Padding (Desktop)" },
    { "type": "range", "id": "pt_d", "min": 0, "max": 150, "step": 5, "unit": "px", "label": "Top", "default": 60 },
    { "type": "range", "id": "pb_d", "min": 0, "max": 150, "step": 5, "unit": "px", "label": "Bottom", "default": 60 },
    { "type": "header", "content": "Padding (Mobile)" },
    { "type": "range", "id": "pt_m", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Top Mobile", "default": 30 },
    { "type": "range", "id": "pb_m", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Bottom Mobile", "default": 30 }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "CX Heading (Nested)",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Heading Inside Container" },
        { "type": "color", "id": "color", "label": "Color", "default": "#000000" },
        { "type": "range", "id": "size", "min": 10, "max": 100, "label": "Font Size", "default": 32 },
        { "type": "select", "id": "align", "label": "Alignment", "options": [
            {"value": "left", "label": "Left"}, {"value": "center", "label": "Center"}, {"value": "right", "label": "Right"}
          ], "default": "center"}
      ]
    },
    {
      "type": "liquid",
      "name": "Custom Liquid / HTML",
      "settings": [
        { "type": "liquid", "id": "custom_liquid", "label": "Custom Liquid Code" }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "presets": [ { "name": "CX Container" } ]
}
{% endschema %}