{%- style -%}
  #cx-container-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.pt_d }}px;
    padding-bottom: {{ section.settings.pb_d }}px;
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
    {% endif %}
    width: 100%;
  }

  /* 🟢 THE BOOTSTRAP CONTAINER LOGIC */
  .cx-bootstrap-container {
    margin: 0 auto;
    width: 100%;
    transition: all 0.3s ease;
    {% if section.settings.no_gutter %}
      max-width: 100% !important; /* Full Width (1920px+) */
      padding: 0;
    {% else %}
      max-width: 1440px !important; /* Bootstrap-like Container */
      padding: 0 20px;
    {% endif %}
  }

  @media screen and (max-width: 750px) {
    #cx-container-{{ section.id }} {
      padding-top: {{ section.settings.pt_m }}px;
      padding-bottom: {{ section.settings.pb_m }}px;
    }
  }

  /* Space between blocks inside the container */
  .cx-block-spacing { margin-bottom: 30px; }
  .cx-block-spacing:last-child { margin-bottom: 0; }
{%- endstyle -%}

<div id="cx-container-{{ section.id }}" class="cx-section-wrapper">
  <div class="cx-bootstrap-container">
    
    {%- for block in section.blocks -%}
      <div class="cx-block-spacing" {{ block.shopify_attributes }}>
        
        {%- case block.type -%}
          
          {%- when 'heading' -%}
            <div style="text-align: {{ block.settings.align }};">
              <h2 style="color: {{ block.settings.color }}; font-size: {{ block.settings.size }}px; margin: 0;">
                {{ block.settings.text }}
              </h2>
            </div>

          {%- when 'custom_html' -%}
            {%- comment -%} 
              Yahan tum kisi bhi dusre section ka HTML code 
              copy-paste kar sakte ho! 
            {%- endcomment -%}
            {{ block.settings.html_code }}

          {%- when 'image' -%}
            <div style="width: 100%;">
              <img src="{{ block.settings.img | image_url: width: 1440 }}" style="width: 100%; height: auto; display: block;">
            </div>

        {%- endcase -%}
        
      </div>
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "CX-Container-Master",
  "settings": [
    { "type": "checkbox", "id": "no_gutter", "label": "No Gutter (Full Width)", "default": false },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "image_picker", "id": "bg_image", "label": "Background Image" },
    { "type": "header", "content": "Desktop Padding" },
    { "type": "range", "id": "pt_d", "min": 0, "max": 150, "step": 5, "label": "Top Padding", "default": 60 },
    { "type": "range", "id": "pb_d", "min": 0, "max": 150, "step": 5, "label": "Bottom Padding", "default": 60 },
    { "type": "header", "content": "Mobile Padding" },
    { "type": "range", "id": "pt_m", "min": 0, "max": 100, "step": 5, "label": "Top Padding Mobile", "default": 30 },
    { "type": "range", "id": "pb_m", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Bottom Padding Mobile", "default": 30 }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Container Heading" },
        { "type": "color", "id": "color", "label": "Color", "default": "#000000" },
        { "type": "range", "id": "size", "min": 10, "max": 100, "label": "Font Size", "default": 32 },
        { "type": "select", "id": "align", "label": "Alignment", "options": [
            {"value": "left", "label": "Left"}, {"value": "center", "label": "Center"}, {"value": "right", "label": "Right"}
          ], "default": "center"}
      ]
    },
    {
      "type": "custom_html",
      "name": "Custom HTML/Section Code",
      "settings": [
        { "type": "html", "id": "html_code", "label": "Paste HTML Here" }
      ]
    },
    {
      "type": "image",
      "name": "Image Block",
      "settings": [
        { "type": "image_picker", "id": "img", "label": "Select Image" }
      ]
    }
  ],
  "presets": [ { "name": "CX-Container-Master" } ]
}
{% endschema %}