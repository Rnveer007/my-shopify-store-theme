{%- style -%}
  #cx-master-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.pt_d }}px 0 {{ section.settings.pb_d }}px 0;
  }
  .cx-container-inner {
    margin: 0 auto;
    width: 100%;
    {% if section.settings.no_gutter %}
      max-width: 100%;
      padding: 0;
    {% else %}
      max-width: 1440px;
      padding: 0 20px;
    {% endif %}
  }
  @media screen and (max-width: 750px) {
    #cx-master-{{ section.id }} { padding: {{ section.settings.pt_m }}px 0 {{ section.settings.pb_m }}px 0; }
  }
  .cx-block-wrapper { margin-bottom: 30px; width: 100%; }
{%- endstyle -%}

<div id="cx-master-{{ section.id }}">
  <div class="cx-container-inner">
    {% for block in section.blocks %}
      <div class="cx-block-wrapper" {{ block.shopify_attributes }}>
        {% case block.type %}
          
          {% when 'heading' %}
            <div style="text-align: {{ block.settings.align }};">
              <h2 style="font-size: {{ block.settings.size }}px; color: {{ block.settings.color }}; margin: 0;">{{ block.settings.text }}</h2>
            </div>

          {% when 'split' %}
             <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 30px; flex-direction: {% if block.settings.pos == 'right' %}row-reverse{% else %}row{% endif %};">
                <div style="flex: 1; min-width: 300px;">
                  <img src="{{ block.settings.img | image_url: width: 800 }}" style="width: 100%; border-radius: 10px;">
                </div>
                <div style="flex: 1; min-width: 300px;">
                  <h3>{{ block.settings.title }}</h3>
                  <div>{{ block.settings.desc }}</div>
                </div>
             </div>

          {% when 'liquid' %}
            {{ block.settings.custom_liquid }}

        {% endcase %}
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "CX Container Master",
  "settings": [
    { "type": "checkbox", "id": "no_gutter", "label": "No Gutter (Full Width)", "default": false },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "range", "id": "pt_d", "min": 0, "max": 100, "label": "Top Padding Desktop", "default": 40 },
    { "type": "range", "id": "pb_d", "min": 0, "max": 100, "label": "Bottom Padding Desktop", "default": 40 },
    { "type": "range", "id": "pt_m", "min": 0, "max": 100, "label": "Top Padding Mobile", "default": 20 },
    { "type": "range", "id": "pb_m", "min": 0, "max": 100, "label": "Bottom Padding Mobile", "default": 20 }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "CX Heading",
      "settings": [
        { "type": "text", "id": "text", "label": "Heading", "default": "Heading Text" },
        { "type": "range", "id": "size", "min": 20, "max": 80, "label": "Size", "default": 32 },
        { "type": "color", "id": "color", "label": "Color", "default": "#000000" },
        { "type": "select", "id": "align", "label": "Align", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"}], "default": "center" }
      ]
    },
    {
      "type": "split",
      "name": "CX Split Feature",
      "settings": [
        { "type": "image_picker", "id": "img", "label": "Image" },
        { "type": "select", "id": "pos", "label": "Position", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "left" },
        { "type": "text", "id": "title", "label": "Title", "default": "Story" },
        { "type": "richtext", "id": "desc", "label": "Desc", "default": "<p>Content</p>" }
      ]
    },
    {
      "type": "liquid",
      "name": "Custom Liquid",
      "settings": [ { "type": "liquid", "id": "custom_liquid", "label": "Code" } ]
    }
  ],
  "presets": [ { "name": "CX Container Master" } ]
}
{% endschema %}