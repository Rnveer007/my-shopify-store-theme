{%- comment -%} CSS Render from Snippets {%- endcomment -%}
{% render 'cx-custom-heading-css', section: section %}

{%- comment -%} JS Connect {%- endcomment -%}
<script src="{{ 'cx-custom-heading.js' | asset_url }}" defer="defer"></script>

<div class="custom-hero-section" id="hero-{{ section.id }}">
  <div class="hero-image-wrapper">
    {% if section.settings.desktop_image != blank %}
      <img src="{{ section.settings.desktop_image | image_url: width: 2000 }}" class="hero-img desktop-only" loading="lazy">
    {% endif %}
    {% if section.settings.mobile_image != blank %}
      <img src="{{ section.settings.mobile_image | image_url: width: 800 }}" class="hero-img mobile-only" loading="lazy">
    {% endif %}
    <div class="hero-overlay-layer" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  </div>

  <div class="hero-content">
    {%- comment -%} 🟢 HTML Block logic {%- endcomment -%}
    {%- assign custom_html = section.settings.custom_html | strip -%}
    {% if custom_html != blank %}
      <div class="hero-custom-html">
        {{ custom_html }}
      </div>
    {% endif %}

    {%- comment -%} 🟢 Title Block logic {%- endcomment -%}
    {%- assign title = section.settings.title | strip -%}
    {% if title != blank %}
      <h1 class="hero-title" style="
        margin-top: {{ section.settings.title_mt }}px; 
        margin-bottom: {{ section.settings.title_mb }}px;
        padding-top: {{ section.settings.title_pt }}px;
        padding-bottom: {{ section.settings.title_pb }}px;
      ">
        {{ title }}
      </h1>
    {% endif %}

    {%- comment -%} 🟢 Sub-Title Block logic (Strict Check) {%- endcomment -%}
    {%- assign subtitle = section.settings.subtitle | strip -%}
    {% if subtitle != blank %}
      <h2 class="hero-subtitle" style="
        margin-top: {{ section.settings.subtitle_mt }}px;
        margin-bottom: {{ section.settings.subtitle_mb }}px;
        padding-top: {{ section.settings.subtitle_pt }}px;
        padding-bottom: {{ section.settings.subtitle_pb }}px;
      ">
        {{ subtitle }}
      </h2>
    {% endif %}

    {%- comment -%} 🟢 Paragraph Block logic {%- endcomment -%}
    {%- assign paragraph = section.settings.paragraph_text | strip -%}
    {% if paragraph != blank %}
      <p class="hero-paragraph" style="
        margin-top: {{ section.settings.para_mt }}px;
        margin-bottom: {{ section.settings.para_mb }}px;
        padding-top: {{ section.settings.para_pt }}px;
        padding-bottom: {{ section.settings.para_pb }}px;
      ">
        {{ paragraph }}
      </p>
    {% endif %}
    
    {%- comment -%} 🟢 Button Block logic {%- endcomment -%}
    {%- assign btn_label = section.settings.btn_label | strip -%}
    {% if btn_label != blank %}
      <a href="{{ section.settings.btn_link }}" class="hero-btn" style="margin-top: {{ section.settings.btn_mt }}px;">
        {{ btn_label }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "CX Custom Heading",
  "settings": [
    { "type": "header", "content": "1. Background Settings" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop Image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile Image" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 90, "step": 10, "label": "Overlay Darkness", "default": 0 },
    { "type": "select", "id": "text_align", "label": "Content Alignment", "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ], "default": "center" },

    { "type": "header", "content": "2. Custom HTML Settings" },
    { "type": "html", "id": "custom_html", "label": "Custom HTML / Code" },
    { "type": "range", "id": "html_mt", "min": 0, "max": 100, "step": 2, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "html_mb", "min": 0, "max": 100, "step": 2, "label": "Margin Bottom", "default": 10 },
    { "type": "range", "id": "html_pt", "min": 0, "max": 100, "step": 2, "label": "Padding Top", "default": 0 },
    { "type": "range", "id": "html_pb", "min": 0, "max": 100, "step": 2, "label": "Padding Bottom", "default": 0 },

    { "type": "header", "content": "3. Heading Settings" },
    { "type": "text", "id": "title", "label": "Text", "default": "" },
    { "type": "color", "id": "title_color", "label": "Color", "default": "#000000" },
    { "type": "range", "id": "title_size", "label": "Desktop Size", "min": 20, "max": 100, "default": 60 },
    { "type": "range", "id": "title_size_mobile", "label": "Mobile Size", "min": 15, "max": 60, "default": 30 },
    { "type": "range", "id": "title_mt", "min": 0, "max": 100, "step": 2, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "title_mb", "min": 0, "max": 100, "step": 2, "label": "Margin Bottom", "default": 10 },
    { "type": "range", "id": "title_pt", "min": 0, "max": 100, "step": 2, "label": "Padding Top", "default": 0 },
    { "type": "range", "id": "title_pb", "min": 0, "max": 100, "step": 2, "label": "Padding Bottom", "default": 0 },

    { "type": "header", "content": "4. Sub-Heading Settings" },
    { "type": "text", "id": "subtitle", "label": "Text", "default": "" },
    { "type": "color", "id": "subtitle_color", "label": "Color", "default": "#000000" },
    { "type": "range", "id": "subtitle_size", "label": "Desktop Size", "min": 15, "max": 60, "default": 30 },
    { "type": "range", "id": "subtitle_size_mobile", "label": "Mobile Size", "min": 12, "max": 40, "default": 20 },
    { "type": "range", "id": "subtitle_mt", "min": 0, "max": 100, "step": 2, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "subtitle_mb", "min": 0, "max": 100, "step": 2, "label": "Margin Bottom", "default": 0 },
    { "type": "range", "id": "subtitle_pt", "min": 0, "max": 100, "step": 2, "label": "Padding Top", "default": 0 },
    { "type": "range", "id": "subtitle_pb", "min": 0, "max": 100, "step": 2, "label": "Padding Bottom", "default": 0 },

    { "type": "header", "content": "5. Paragraph Settings" },
    { "type": "textarea", "id": "paragraph_text", "label": "Text", "default": "" },
    { "type": "color", "id": "para_color", "label": "Color", "default": "#000000" },
    { "type": "range", "id": "para_size", "label": "Size (Desktop)", "min": 12, "max": 30, "default": 18 },
    { "type": "range", "id": "para_size_mobile", "label": "Size (Mobile)", "min": 10, "max": 25, "default": 14 },
    { "type": "range", "id": "para_mt", "min": 0, "max": 100, "step": 2, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "para_mb", "min": 0, "max": 100, "step": 2, "label": "Margin Bottom", "default": 20 },
    { "type": "range", "id": "para_pt", "min": 0, "max": 100, "step": 2, "label": "Padding Top", "default": 0 },
    { "type": "range", "id": "para_pb", "min": 0, "max": 100, "step": 2, "label": "Padding Bottom", "default": 0 },

    { "type": "header", "content": "6. Button Settings" },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "" },
    { "type": "url", "id": "btn_link", "label": "Button Link" },
    { "type": "color", "id": "btn_color", "label": "Button Color", "default": "#000000" },
    { "type": "color", "id": "btn_text_color", "label": "Button Text Color", "default": "#ffffff" },
    { "type": "range", "id": "btn_mt", "min": 0, "max": 100, "step": 2, "label": "Margin Top", "default": 10 }
  ],
  "presets": [ { "name": "CX Custom Heading" } ]
}
{% endschema %}