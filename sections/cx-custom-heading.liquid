<div class="custom-hero-section" id="hero-{{ section.id }}">
  <div class="hero-image-wrapper">
    {% if section.settings.desktop_image != blank %}
      <img src="{{ section.settings.desktop_image | image_url: width: 2000 }}" class="hero-img desktop-only">
    {% endif %}
    {% if section.settings.mobile_image != blank %}
      <img src="{{ section.settings.mobile_image | image_url: width: 800 }}" class="hero-img mobile-only">
    {% endif %}
    <div class="hero-overlay-layer"></div>
  </div>

  <div class="hero-content">
    <h1 class="hero-title">{{ section.settings.title }}</h1>
    <h2 class="hero-subtitle">{{ section.settings.subtitle }}</h2>
    <p class="hero-paragraph">{{ section.settings.paragraph_text }}</p>
    
    {% if section.settings.btn_label != blank %}
      <a href="{{ section.settings.btn_link }}" class="hero-btn">{{ section.settings.btn_label }}</a>
    {% endif %}
  </div>
</div>

<style>
  #hero-{{ section.id }} { 
    position: relative; width: 100%; min-height: 450px;
    background-color: {{ section.settings.bg_color }}; 
    display: flex; align-items: center; justify-content: center; overflow: hidden;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .hero-content { position: relative; z-index: 5; width: 80%; text-align: {{ section.settings.text_align }}; }

  .hero-title { 
    margin-top: {{ section.settings.title_mt }}px;
    margin-bottom: {{ section.settings.title_mb }}px;
    color: {{ section.settings.title_color }};
    font-weight: bold; line-height: 1.1;
  }
  
  .hero-subtitle { 
    margin-top: {{ section.settings.subtitle_mt }}px;
    margin-bottom: {{ section.settings.subtitle_mb }}px;
    color: {{ section.settings.subtitle_color }};
  }

  .hero-paragraph { 
    margin-top: {{ section.settings.para_mt }}px;
    margin-bottom: {{ section.settings.para_mb }}px;
    color: {{ section.settings.para_color }};
    line-height: 1.4;
  }

  @media screen and (min-width: 751px) {
    .hero-title { font-size: {{ section.settings.title_size }}px; }
    .hero-subtitle { font-size: {{ section.settings.subtitle_size }}px; }
    .hero-paragraph { font-size: {{ section.settings.para_size }}px; }
  }
  @media screen and (max-width: 750px) {
    .hero-title { font-size: {{ section.settings.title_size_mobile }}px; }
    .hero-subtitle { font-size: {{ section.settings.subtitle_size_mobile }}px; }
    .hero-paragraph { font-size: {{ section.settings.para_size_mobile }}px; }
  }
  
  .hero-btn {
    display: inline-block; padding: 14px 35px;
    background-color: {{ section.settings.btn_color }};
    color: {{ section.settings.btn_text_color }} !important;
    text-decoration: none; border-radius: 4px; font-weight: bold;
    margin-top: {{ section.settings.btn_mt }}px;
  }
</style>

{% schema %}
{
  "name": "CX Custom Heading",
  "settings": [
    { "type": "header", "content": "1. Background Settings" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop Image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile Image" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 90, "step": 10, "label": "Overlay Darkness", "default": 0 },
    { "type": "select", "id": "text_align", "label": "Content Alignment", "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ], "default": "center" },

    { "type": "header", "content": "2. Heading Settings" },
    { "type": "text", "id": "title", "label": "Text", "default": "Main Title" },
    { "type": "color", "id": "title_color", "label": "Color", "default": "#000000" },
    { "type": "range", "id": "title_size", "label": "Desktop Size", "min": 20, "max": 100, "default": 60 },
    { "type": "range", "id": "title_size_mobile", "label": "Mobile Size", "min": 15, "max": 60, "default": 30 },
    { "type": "range", "id": "title_mt", "min": 0, "max": 100, "step": 2, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "title_mb", "min": 0, "max": 100, "step": 2, "label": "Margin Bottom", "default": 10 },

    { "type": "header", "content": "3. Sub-Heading Settings" },
    { "type": "text", "id": "subtitle", "label": "Text", "default": "Sub-Heading" },
    { "type": "color", "id": "subtitle_color", "label": "Color", "default": "#000000" },
    { "type": "range", "id": "subtitle_size", "label": "Desktop Size", "min": 15, "max": 60, "default": 30 },
    { "type": "range", "id": "subtitle_size_mobile", "label": "Mobile Size", "min": 12, "max": 40, "default": 20 },
    { "type": "range", "id": "subtitle_mt", "min": 0, "max": 100, "step": 2, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "subtitle_mb", "min": 0, "max": 100, "step": 2, "label": "Margin Bottom", "default": 16 },

    { "type": "header", "content": "4. Paragraph Settings" },
    { "type": "textarea", "id": "paragraph_text", "label": "Text", "default": "Your brand story goes here." },
    { "type": "color", "id": "para_color", "label": "Color", "default": "#000000" },
    { "type": "range", "id": "para_size", "label": "Size (Desktop)", "min": 12, "max": 30, "default": 18 },
    { "type": "range", "id": "para_size_mobile", "label": "Size (Mobile)", "min": 10, "max": 25, "default": 14 },
    { "type": "range", "id": "para_mt", "min": 0, "max": 100, "step": 2, "label": "Margin Top", "default": 0 },
    { "type": "range", "id": "para_mb", "min": 0, "max": 100, "step": 2, "label": "Margin Bottom", "default": 20 },

    { "type": "header", "content": "5. Button Settings" },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "Shop Now" },
    { "type": "url", "id": "btn_link", "label": "Button Link" },
    { "type": "color", "id": "btn_color", "label": "Button Color", "default": "#000000" },
    { "type": "color", "id": "btn_text_color", "label": "Button Text Color", "default": "#000000" },
    { "type": "range", "id": "btn_mt", "min": 0, "max": 100, "step": 2, "label": "Margin Top", "default": 10 },

    { "type": "header", "content": "6. Overall Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 5, "label": "Padding Top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 5, "label": "Padding Bottom", "default": 40 }
  ],
  "presets": [ { "name": "CX Custom Heading" } ]
}
{% endschema %}