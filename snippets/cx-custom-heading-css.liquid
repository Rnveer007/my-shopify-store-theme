<style>
  #hero-{{ section.id }} { 
    position: relative; width: 100%; min-height: auto;
    background-color: {{ section.settings.bg_color }}; 
    display: flex; align-items: center; justify-content: center; overflow: hidden;
    padding: 40px 0;
  }
  .hero-image-wrapper { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; }
  .hero-img { width: 100%; height: 100%; object-fit: cover; position: absolute; }
  .hero-overlay-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: #000; z-index: 2; }
  .hero-content { position: relative; z-index: 5; width: 90%; text-align: {{ section.settings.text_align }}; }

  .hero-title { color: {{ section.settings.title_color }}; font-weight: bold; line-height: 1.1; margin: 0; }
  .hero-subtitle { color: {{ section.settings.subtitle_color }}; line-height: 1.2; margin: 0; }
  .hero-paragraph { color: {{ section.settings.para_color }}; line-height: 1.4; margin: 0; }

  @media screen and (min-width: 751px) {
    .hero-title { font-size: {{ section.settings.title_size }}px; }
    .hero-subtitle { font-size: {{ section.settings.subtitle_size }}px; }
    .hero-paragraph { font-size: {{ section.settings.para_size }}px; }
    .desktop-only { display: block; }
    .mobile-only { display: none; }
  }
  @media screen and (max-width: 750px) {
    .hero-title { font-size: {{ section.settings.title_size_mobile }}px; }
    .hero-subtitle { font-size: {{ section.settings.subtitle_size_mobile }}px; }
    .hero-paragraph { font-size: {{ section.settings.para_size_mobile }}px; }
    .desktop-only { display: none; }
    .mobile-only { display: block; }
  }
  .hero-btn { display: inline-block; padding: 14px 35px; background: {{ section.settings.btn_color }}; color: {{ section.settings.btn_text_color }} !important; text-decoration: none; border-radius: 4px; font-weight: bold; }
</style>