<style>
  #hero-{{ section.id }} { 
    position: relative; width: 100%; min-height: 450px;
    background-color: {{ section.settings.bg_color }}; 
    display: flex; align-items: center; justify-content: center; overflow: hidden;
  }

  .hero-image-wrapper { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; }
  .hero-img { width: 100%; height: 100%; object-fit: cover; position: absolute; }
  .hero-overlay-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: #000; z-index: 2; }
  
  .hero-content { position: relative; z-index: 5; width: 80%; text-align: {{ section.settings.text_align }}; }

  .hero-custom-html {
    margin-top: {{ section.settings.html_mt }}px;
    margin-bottom: {{ section.settings.html_mb }}px;
    padding-top: {{ section.settings.html_pt }}px;
    padding-bottom: {{ section.settings.html_pb }}px;
    word-break: break-word;
  }

  .hero-title { 
    color: {{ section.settings.title_color }};
    font-weight: bold; line-height: 1.1;
    margin-top: {{ section.settings.title_mt }}px;
    margin-bottom: {{ section.settings.title_mb }}px;
    padding-top: {{ section.settings.title_pt }}px;
    padding-bottom: {{ section.settings.title_pb }}px;
  }
  
  .hero-subtitle { 
    color: {{ section.settings.subtitle_color }};
    margin-top: {{ section.settings.subtitle_mt }}px;
    margin-bottom: {{ section.settings.subtitle_mb }}px;
    padding-top: {{ section.settings.subtitle_pt }}px;
    padding-bottom: {{ section.settings.subtitle_pb }}px;
  }

  .hero-paragraph { 
    color: {{ section.settings.para_color }};
    line-height: 1.4;
    margin-top: {{ section.settings.para_mt }}px;
    margin-bottom: {{ section.settings.para_mb }}px;
    padding-top: {{ section.settings.para_pt }}px;
    padding-bottom: {{ section.settings.para_pb }}px;
  }

  @media screen and (min-width: 751px) {
    .hero-title { font-size: {{ section.settings.title_size }}px; }
    .hero-subtitle { font-size: {{ section.settings.subtitle_size }}px; }
    .hero-paragraph { font-size: {{ section.settings.para_size }}px; }
    .desktop-only { display: block; }
    .mobile-only { display: none; }
  }

  @media screen and (max-width: 750px) {
    .hero-title { font-size: {{ section.settings.title_size_mobile }}px; }
    .hero-subtitle { font-size: {{ section.settings.subtitle_size_mobile }}px; }
    .hero-paragraph { font-size: {{ section.settings.para_size_mobile }}px; }
    .desktop-only { display: none; }
    .mobile-only { display: block; }
  }
  
  .hero-btn {
    display: inline-block; padding: 14px 35px;
    background-color: {{ section.settings.btn_color }};
    color: {{ section.settings.btn_text_color }} !important;
    text-decoration: none; border-radius: 4px; font-weight: bold;
    margin-top: {{ section.settings.btn_mt }}px;
    transition: opacity 0.3s ease;
  }
  .hero-btn:hover { opacity: 0.8; }
</style>